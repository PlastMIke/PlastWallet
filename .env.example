# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env and update with your values
# DO NOT commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
VERSION=0.0.1-SNAPSHOT
SPRING_PROFILES_ACTIVE=docker

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=jdbc:postgresql://postgres:5432/wallet_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DB_PORT=5432
POSTGRES_DB=wallet_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Kafka Configuration
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_HOST=localhost
KAFKA_PORT=9092

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
JWT_SECRET=VGhpc0lzQVNlY3JldEtleUZvckpXVEF1dGhlbnRpY2F0aW9uU2VydmljZTIwMjQh
JWT_EXPIRATION=86400000

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOGGING_LEVEL=INFO
LOGGING_LEVEL_ROOT=INFO

# -----------------------------------------------------------------------------
# JVM Configuration
# -----------------------------------------------------------------------------
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# -----------------------------------------------------------------------------
# Production Specific (uncomment and configure for production)
# -----------------------------------------------------------------------------
# DATABASE_PASSWORD=your_secure_production_password
# REDIS_PASSWORD=your_secure_redis_password
# JWT_SECRET=your_very_long_and_secure_jwt_secret_key_at_least_32_chars
