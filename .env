# =============================================================================
# PlastWallet Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
VERSION=0.0.1-SNAPSHOT
SPRING_PROFILES_ACTIVE=docker

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=jdbc:postgresql://postgres:5432/wallet_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DB_PORT=5432
POSTGRES_DB=wallet_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Kafka Configuration
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_HOST=localhost
KAFKA_PORT=9092

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
JWT_SECRET=VGhpc0lzQVNlY3JldEtleUZvckpXVEF1dGhlbnRpY2F0aW9uU2VydmljZTIwMjQh
JWT_EXPIRATION=86400000

# -----------------------------------------------------------------------------
# Telegram Bot Configuration
# -----------------------------------------------------------------------------
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_BOT_USERNAME=PlastWalletMonitorBot
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Notification settings
TELEGRAM_NOTIFICATIONS_DAILY_REPORT_ENABLED=true
TELEGRAM_NOTIFICATIONS_HEALTH_CHECK_ENABLED=true
TELEGRAM_NOTIFICATIONS_MORNING_SUMMARY_ENABLED=true

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOGGING_LEVEL=INFO
LOGGING_LEVEL_ROOT=INFO

# -----------------------------------------------------------------------------
# JVM Configuration
# -----------------------------------------------------------------------------
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseG1GC -XX:MaxGCPauseMillis=200
